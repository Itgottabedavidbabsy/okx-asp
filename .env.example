# ── Application ─────────────────────────────────────────────
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:5173

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/okxasp

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=replace_with_64_char_random_secret
JWT_EXPIRES_IN=7d

# ── OKX OAuth ─────────────────────────────────────────────────
OKX_CLIENT_ID=your_okx_client_id
OKX_CLIENT_SECRET=your_okx_client_secret
OKX_REDIRECT_URI=http://localhost:4000/api/auth/okx/callback
OKX_AUTH_URL=https://www.okx.com/oauth/authorize
OKX_TOKEN_URL=https://www.okx.com/oauth/token
OKX_API_BASE=https://www.okx.com/api/v5

# ── OKX WebSocket ─────────────────────────────────────────────
OKX_WS_URL=wss://ws.okx.com:8443/ws/v5/public
OKX_WS_PRIVATE_URL=wss://ws.okx.com:8443/ws/v5/private

# ── On-Chain Performance Ledger ────────────────────────────────
# Leave unset to run in simulated-anchor mode (hashing + Merkle proofs still
# fully work; only the final chain write is mocked). Fill in to anchor for real
# on a cheap L2/testnet (e.g. Sepolia, Polygon Amoy, Base Sepolia).
LEDGER_RPC_URL=
LEDGER_PRIVATE_KEY=
LEDGER_CHAIN_NAME=ethereum-sepolia
LEDGER_ANCHOR_INTERVAL_MS=600000
